# syntax=docker/dockerfile:1.7
# Builds the sample "chat-demo" backend. Kept intentionally tiny so newcomers can
# read Program.cs + one Dockerfile and understand the llmtrans integration surface.
FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY examples/chat-demo/backend/ChatDemo.csproj examples/chat-demo/backend/
RUN dotnet restore examples/chat-demo/backend/ChatDemo.csproj

COPY examples/chat-demo/backend/ examples/chat-demo/backend/
RUN dotnet publish examples/chat-demo/backend/ChatDemo.csproj -c Release -o /app --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends wget ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY --from=build /app ./

ENV ASPNETCORE_URLS=http://+:5100 \
    ASPNETCORE_ENVIRONMENT=Production

EXPOSE 5100

HEALTHCHECK --interval=15s --timeout=3s --start-period=10s --retries=5 \
    CMD wget -qO- http://localhost:5100/healthz > /dev/null 2>&1 || exit 1

ENTRYPOINT ["dotnet", "ChatDemo.dll"]
