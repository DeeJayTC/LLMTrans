# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS build
WORKDIR /src

COPY examples/chat-demo/ui/package.json examples/chat-demo/ui/package-lock.json* ./
RUN npm install --no-audit --no-fund

COPY examples/chat-demo/ui/ ./
RUN npm run build

FROM nginx:1.27-alpine AS runtime
COPY --from=build /src/dist /usr/share/nginx/html
COPY deploy/docker/nginx.demo.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
