# Copy to `.env` (not committed) and edit.
# docker compose reads `.env` automatically when run from `deploy/`.

# --- ports ---
API_PORT=8080
UI_PORT=8000

# --- env ---
ASPNETCORE_ENVIRONMENT=Development

# --- translator backends (at least one is required for real translation;
#                         default is `passthrough` which leaves text unchanged) ---
LLMTRANS_DEFAULT_TRANSLATOR=passthrough      # or: deepl | llm | passthrough
DEEPL_API_KEY=xxx
DEEPL_BASE_URL=https://api.deepl.com/        # use https://api-free.deepl.com/ for DeepL Free
LLM_TRANSLATOR_API_KEY=
LLM_TRANSLATOR_BASE_URL=https://api.openai.com/
LLM_TRANSLATOR_MODEL=gpt-4o-mini

# --- seed a known route token so you can `curl` immediately (dev only) ---
DEV_FIXED_ROUTE_TOKEN=rt_dev_LOCALDEMO

# --- public base URL advertised by the snippet generator ---
PUBLIC_BASE_URL=http://localhost:8080

# --- chat-demo sample (opt-in via `docker compose --profile demo up`) ---
# The demo backend uses OPENAI_API_KEY to actually reach OpenAI. Without it, the
# demo UI still loads but every request fails at the upstream.
OPENAI_API_KEY=xxx
DEMO_API_PORT=5100
DEMO_UI_PORT=8100
DEMO_MODEL=gpt-4o-mini
DEMO_LLM_LANGUAGE=en-US
DEMO_TEMPERATURE=0.3

# WARNING: surfaces the raw OpenAI + DeepL request/response bodies in the demo
# pipeline log for debugging. Only safe on a developer machine — payloads can
# include the user's original message and the upstream LLM's full reply.
# Set to false before exposing the demo to anyone else's traffic.
DEMO_INCLUDE_PAYLOADS=true
